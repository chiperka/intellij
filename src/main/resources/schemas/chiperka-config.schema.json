{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chiperka Configuration",
  "description": "Schema for Chiperka configuration files (chiperka.yaml / chiperka.yml)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "discovery": {
      "type": "array",
      "description": "Paths to recursively scan for .chiperka specification files (tests and services)",
      "items": {
        "type": "string"
      }
    },
    "executionVariables": {
      "type": "object",
      "description": "Variables passed to test execution environment",
      "additionalProperties": {
        "type": "string"
      }
    },
    "cloud": {
      "type": "object",
      "description": "Cloud execution configuration",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "Cloud API server URL (e.g. https://chiperka.com)"
        },
        "project": {
          "type": "string",
          "description": "Project slug for cloud runs"
        }
      }
    }
  }
}
